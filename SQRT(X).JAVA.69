class Solution {
    public int mySqrt(int x) {
        if (x < 2) {
            return x;
        }

        int left = 1;
        int right = x / 2;
        int ans = 0;

        while (left <= right) {
            int mid = left + (right - left) / 2;

            if (mid <= x / mid) { // Equivalent to mid * mid <= x, but avoids overflow
                ans = mid;        // Store possible answer
                left = mid + 1;   // Try searching for a larger square root
            } else {
                right = mid - 1;  // Search in the lower half
            }
        }

        return ans;
    }
}
